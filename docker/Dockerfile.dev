# =============================================================================
# Dev image — same binary as release but runs in debug mode; tagged :devel
# =============================================================================
# Build Stage - Compile Go binary with debug info
FROM casjaysdev/go:latest AS builder

RUN apk add --no-cache git bash

ARG TARGETARCH
ARG VERSION=devel
ARG BUILD_DATE
ARG COMMIT_ID
ARG OFFICIAL_SITE=

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH} go build -buildvcs=false \
    -ldflags "-X 'main.Version=${VERSION}' -X 'main.CommitID=${COMMIT_ID}' -X 'main.BuildDate=${BUILD_DATE}' -X 'main.OfficialSite=${OFFICIAL_SITE}'" \
    -o /app/binary/caswhois ./src

# =============================================================================
# Runtime Stage - Alpine with debug tools
# =============================================================================
FROM alpine:latest

ARG VERSION=devel
ARG BUILD_DATE
ARG COMMIT_ID

RUN apk add --no-cache \
    git \
    curl \
    bash \
    tini \
    tor \
    ca-certificates \
    tzdata \
    wget \
    netcat-openbsd

RUN addgroup -S caswhois && adduser -S -G caswhois caswhois

COPY --from=builder /app/binary/caswhois /usr/local/bin/caswhois
COPY docker/rootfs/ /
COPY docker/Dockerfile.dev /root/Dockerfile.dev

RUN chmod 755 /usr/local/bin/*

ENV MODE=development \
    TZ=America/New_York \
    DATABASE_DIR=/data/db/sqlite \
    DEBUG=true

EXPOSE 80

STOPSIGNAL SIGRTMIN+3

HEALTHCHECK --start-period=5m --interval=2m --timeout=15s --retries=3 \
    CMD /usr/local/bin/caswhois --status || exit 1

ENTRYPOINT [ "tini", "-p", "SIGTERM", "--", "/usr/local/bin/entrypoint.sh" ]
